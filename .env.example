# Copy this file to .env and edit values as needed for your machine
# Keys here will be read by tools (runner) and by the generator if not overridden by CLI flags

# Iterations and variant
# HSI_ITERATIONS=18
# HSI_VARIANT_CODE=B

# Logging and timing
HSI_LOG_EVERY=1
HSI_ENABLE_TIMING=1
HSI_COMPRESS_LOG=1

# Compression level for gzip (1=fastest, 9=best ratio)
HSI_COMPRESSION_LEVEL=5

# Snapshots cleanup (keep only the last N snapshots at the end of a run)
HSI_CLEANUP_KEEP_LAST=2

