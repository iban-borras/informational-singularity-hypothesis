# =============================================================================
# HSI Agents Project - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Results folder - EXCLUDE (contains GB of generated data)
# -----------------------------------------------------------------------------
results/

# -----------------------------------------------------------------------------
# Python cache
# -----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.so

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------------
# Environment variables
# -----------------------------------------------------------------------------
.env
!.env.example

# -----------------------------------------------------------------------------
# Logs and temp files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
setup_log.txt

# -----------------------------------------------------------------------------
# Cache and large binary files
# -----------------------------------------------------------------------------
*.pkl
*.cache
*.bin
*.bin.gz
*.struct.gz
*.tar.gz

# -----------------------------------------------------------------------------
# OS-specific
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Test coverage
# -----------------------------------------------------------------------------
.pytest_cache/
htmlcov/
.coverage
*.coverage

Documentation/archive/
